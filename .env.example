GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://host.docker.internal:11434
REDIS_URL=redis://redis:6379/0
# Optionnel : même valeur que dans docker-compose pour le backend.
# Permet d’appeler les routes /api/players/admin/* avec le header X-TopQuizz-Admin-Token
# quand ton IP n’est pas détectée comme « locale » (ex. reverse proxy, autre sous-réseau).
TOPQUIZZ_ADMIN_TOKEN=
